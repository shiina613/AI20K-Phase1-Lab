# Auto detect text files and normalize line endings to LF
* text=auto

# Python
*.py text eol=lf
*.pyx text eol=lf
*.pyi text eol=lf

# Shell
*.sh text eol=lf
*.bash text eol=lf

# Windows
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Markdown
*.md text eol=lf

# YAML
*.yaml text eol=lf
*.yml text eol=lf

# JSON
*.json text eol=lf
*.jsonl text eol=lf

# CSV
*.csv text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.mov binary
*.mp4 binary
*.mp3 binary
*.gz binary
*.zip binary
*.7z binary
*.ttf binary
*.otf binary
*.db binary
