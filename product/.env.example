# =============================================================================
# .env.example — Cấu hình môi trường cho AI Gia Sư
# =============================================================================
# Copy file này thành .env và điền các giá trị thực tế

# LLM Provider
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-4o
OPENAI_MINI_MODEL=gpt-4o-mini

# Vector Store
VECTOR_STORE_TYPE=chromadb  # chromadb | faiss | qdrant
CHROMADB_PATH=./data/chromadb

# Data
DATA_FOR_RAG_PATH=./data_for_rag

# Monitoring
LANGFUSE_PUBLIC_KEY=your-public-key
LANGFUSE_SECRET_KEY=your-secret-key
LANGFUSE_HOST=https://cloud.langfuse.com

# Logging
LOG_LEVEL=INFO  # DEBUG | INFO | WARNING | ERROR
LOG_FILE=./logs/app.log

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=False

# Database (nếu dùng PostgreSQL cho vector store)
DATABASE_URL=postgresql://user:password@localhost:5432/tutor_ai
